<?xml version="1.0" ?>
<STATES>
	<MENU>
		<TEXTURES>
			<texture filename="assets/1.jpg" ID="playbutton"/>
			<texture filename="assets/2.jpg" ID="exitbutton"/>
		</TEXTURES>
		<OBJECTS>
			<object type="MenuButton" x="100" y="100" width="177" height="46" textureID="playbutton" numFrames="0" callbackID="1"/>
			<object type="MenuButton" x="100" y="300" width="177" height="48" textureID="exitbutton" numFrames="0" callbackID="2"/>
		</OBJECTS>
	</MENU>
	<PLAY>
		<TEXTURES>
			<texture filename="assets/helicopter.png" ID="helicopter"/>
			<texture filename="assets/helicopter2.png" ID="helicopter2"/>
		</TEXTURES>
		<OBJECTS>
			<object type="Player" x="100" y="100" width="128" height="55" textureID="helicopter" numFrames="4"/>
			<object type="Enemy" x="500" y="100" width="128" height="55" textureID="helicopter2" numFrames="4"/>
		</OBJECTS>
	</PLAY>
	<PAUSE>
		<TEXTURES>
			<texture filename="assets/res.jpg" ID="resumebutton"/>
			<texture filename="assets/man.jpg" ID="mainbutton"/>
		</TEXTURES>
		<OBJECTS>
			<object type="MenuButton" x="200" y="100" width="163" height="67" textureID="mainbutton" numFrames="0" callbackID="1"/>
			<object type="MenuButton" x="200" y="300" width="163" height="67" textureID="resumebutton" numFrames="0" callbackID="2"/>
		</OBJECTS>
	</PAUSE>	
	<GAMEOVER>
		<TEXTURES>
			<texture filename="assets/gam.png" ID="gameovertext"/>
			<texture filename="assets/man.jpg" ID="mainbutton"/>
			<texture filename="assets/res.jpg" ID="restartbutton"/>
		</TEXTURES>
		<OBJECTS>	
			<object type="AnimatedGraphic" x="200" y="100" width="238" height="35" textureID="gameovertext" numFrames="2" animSpeed="2" callbackID="2"/>
			<object type="MenuButton" x="200" y="200" width="163" height="67" textureID="mainbutton" numFrames="0" callbackID="1"/>
			<object type="MenuButton" x="200" y="300" width="163" height="67" textureID="restartbutton" numFrames="0" callbackID="2"/>
		</OBJECTS>
	</GAMEOVER>
</STATES>